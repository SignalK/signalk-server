    "@signalk/instrumentpanel": "0.x",
    "@signalk/server-admin-ui": "^2.30.0",
    "@signalk/set-system-time": "^1.5.0",
    "@signalk/signalk-to-nmea0183": "^1.18.0",
    "@signalk/udp-nmea-plugin": "^2.0.0",
    "serialport": "^11.0.1",
    "signalk-n2kais-to-nmea0183": "^2.0.3",
    "signalk-to-nmea2000": "^2.24.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^1.53.1",
    "@eslint/js": "^9.24.0",
    "@signalk/typedoc-signalk-theme": "^0.4.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/busboy": "^1.5.4",
    "@types/chai": "^4.3.20",
    "@types/command-exists": "^1.2.3",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.13",
