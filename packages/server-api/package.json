{
  "name": "@signalk/server-api",
  "version": "2.30.0",
  "description": "signalk-server Typescript API for plugins etc with relevant implementation classes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "ts-auto-guard src/autopilotapi.ts",
    "build": "npm run generate && tsc -b",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "prettier": "prettier --write .",
    "lint": "eslint --fix",
    "format": "npm run prettier && npm run lint",
    "test": "mocha 'src/**/*.test.ts' 'src/*.test.ts'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SignalK/signalk-server.git",
    "directory": "packages/server-api"
  },
  "author": "teppo.kurki@iki.fi",
  "license": "Apache-2.0",
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@signalk/path-metadata": "^1.0.1",
    "@sinclair/typebox": "^0.34.49",
    "baconjs": "^3.0.23"
  },
  "devDependencies": {
    "ts-auto-guard": "^5.1.3"
  },
  "exports": {
    ".": "./dist/index.js",
    "./history": "./dist/history.js",
    "./typebox": "./dist/typebox/index.js"
  },
  "typesVersions": {
    "*": {
      "history": [
        "dist/history.d.ts"
      ],
      "typebox": [
        "dist/typebox/index.d.ts"
      ]
    }
  }
}
